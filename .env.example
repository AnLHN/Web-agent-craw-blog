# Root configuration for setup.sh
# Safe to commit. Do not put secrets here.

# Backend runtime address
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001

# Frontend dev server address
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3005
FRONTEND_PUBLIC_HOST=localhost

# Browser-facing backend host used by frontend API base URL
PUBLIC_BACKEND_HOST=localhost

# Auto start backend and frontend after setup
AUTO_START_APPS=true

# Local vLLM model id
LLM_MODEL=google/gemma-4-E4B-it
