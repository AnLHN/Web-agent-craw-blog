# Production compose template. Copy to a private env file and fill secrets before deploy.
# Do not commit real secrets.

BACKEND_PORT=8011
FRONTEND_PORT=3005

POSTGRES_PORT=5432
POSTGRES_DB=web_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

APP_AUTH_STORE_BACKEND=postgres
APP_AUTH_TOKEN_SECRET=CHANGE_ME_STRONG_RANDOM_TOKEN_SECRET
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
APP_RBAC_ENABLED=true
APP_RBAC_ADMIN_TOKEN=
APP_SESSION_STORE_BACKEND=postgres
APP_SESSION_STORE_DUAL_WRITE=false
APP_CORS_ORIGINS=["http://localhost:3005"]

APP_LLM_ENABLED=true
APP_LLM_BASE_URL=http://host.docker.internal:8007/v1
APP_LLM_MODEL=google/gemma-4-E4B-it
APP_SEARXNG_BASE_URL=http://host.docker.internal:8080

APP_9ROUTER_BASE_URL=http://host.docker.internal:20128/v1
APP_9ROUTER_API_KEY=
APP_WORDPRESS_CHROME_CDP_URL=http://host.docker.internal:9227

NEXT_PUBLIC_FEATURE_SESSION_HISTORY=true
NEXT_PUBLIC_FEATURE_OPS_DASHBOARD=true
NEXT_PUBLIC_FEATURE_LLM_RUNTIME_CONFIG=true
NEXT_PUBLIC_9ROUTER_DASHBOARD_URL=http://localhost:20128/dashboard
