APP_APP_NAME=Web Search API
APP_ENVIRONMENT=development
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=["http://localhost:3000"]

APP_REQUEST_TIMEOUT_SECONDS=12
APP_QUALITY_MIN_RESULTS=3
APP_QUALITY_MIN_UNIQUE_DOMAINS=2
APP_RESULT_CACHE_TTL_SECONDS=300

APP_TAVILY_SEARCH_DEPTH=advanced
APP_TAVILY_MAX_COOLDOWN_SECONDS=600
APP_TAVILY_KEY_STORE_PATH=config/tavily_keys.json
APP_CHAT_SESSION_STORE_PATH=config/chat_sessions.json
APP_DATABASE_URL=
APP_SESSION_STORE_BACKEND=auto
APP_SESSION_STORE_DUAL_WRITE=false
APP_CHAT_SESSION_RETENTION_DAYS=30
APP_LLM_RUNTIME_STORE_PATH=config/llm_runtime.json
APP_AUDIT_LOG_STORE_PATH=config/audit_logs.jsonl
APP_AUTH_STORE_PATH=config/auth_store.json
APP_AUTH_STORE_BACKEND=auto
APP_AUTH_TOKEN_SECRET=change-me-in-production
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
APP_RBAC_ENABLED=false
APP_RBAC_ADMIN_TOKEN=

APP_LLM_ENABLED=true
# LLM endpoint (OpenAI-compatible). Sua IP/host nay neu model host o may khac.
APP_LLM_BASE_URL=http://localhost:8007/v1
APP_LLM_MODEL=google/gemma-4-E4B-it
APP_LLM_TEMPERATURE=0.2
APP_QUERY_ANALYST_MODE=rule
# Optional: de trong de su dung default trong code
APP_LLM_MAX_TOKENS=

APP_SEARXNG_BASE_URL=http://127.0.0.1:8080
APP_SEARXNG_BACKUP_BASE_URLS=
APP_SEARXNG_CATEGORIES=general
APP_SEARXNG_MAX_QPS=1.5
APP_SEARXNG_CIRCUIT_FAIL_THRESHOLD=3
APP_SEARXNG_CIRCUIT_OPEN_SECONDS=120
APP_FORCE_SEARXNG_TEST_MODE=false

# Article Import LLM via local 9Router.
# Start 9Router with: npm install -g 9router && 9router
# Dashboard: http://localhost:20128/dashboard
# API base: http://localhost:20128/v1
APP_ARTICLE_LLM_PROVIDER=9router_openai
APP_9ROUTER_BASE_URL=http://127.0.0.1:20128/v1
APP_9ROUTER_API_KEY=
APP_ARTICLE_OPENAI_MODEL=cx/gpt-5.5
APP_ARTICLE_TRANSLATION_MAX_OUTPUT_TOKENS=10000
APP_ARTICLE_TRANSLATION_MAX_BATCHES_PER_RUN=8
APP_ARTICLE_TRANSLATION_BATCH_SIZE=4
APP_ARTICLE_TRANSLATION_MAX_BATCH_CHARS=10000
